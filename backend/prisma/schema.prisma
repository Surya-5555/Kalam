// =========================
// Prisma Schema - LeetCode-like Platform
// Cleaned version without streak
// =========================

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========================
// USER TABLE
// =========================
model User {
  id                   Int       @id @default(autoincrement())
  name                 String
  role                 String    @default("user")
  email                String    @unique
  isEmailVerified      Boolean   @default(false)
  emailVerifyToken     String?
  password             String
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  lastLoginAt          DateTime?
  loginCount           Int       @default(0)
  isBanned             Boolean   @default(false)
  twoFactorSecret      String?
  profilePicture       String?
  bio                  String?
  experience           Int       @default(0)
  level                Int       @default(1)
  settings             Json?

  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  invoices            InvoiceDocument[]
  generatedInvoices   GeneratedInvoice[]
}

// =========================
// REFRESH TOKEN TABLE
// =========================
model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique // hashed refresh token
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// =========================
// Forget Password
// =========================

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// =========================
// INVOICE DOCUMENTS TABLE
// =========================
model InvoiceDocument {
  id            String   @id @default(uuid())
  userId        Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  originalName  String
  storedName    String
  mimeType      String
  fileSize      Int
  storagePath   String
  status        String   @default("pending") // pending | processing | completed | failed
  extractedData Json?
  uploadedAt    DateTime @default(now())
  updatedAt     DateTime @updatedAt

  processingJob ProcessingJob?

  @@index([userId])
}

// =========================
// PROCESSING JOB TABLE
// Per-document pipeline stage tracker.
// Created at upload time; updated as each stage completes.
// =========================
model ProcessingJob {
  id            String    @id @default(uuid())
  documentId    String    @unique
  document      InvoiceDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  // overall state: processing | completed | failed
  overallStatus String    @default("processing")
  // name of the stage currently executing or that last ran
  currentStage  String    @default("uploaded")
  // JSON array of StageRecord objects (see processing-status.service.ts)
  stages        Json
  failureReason String?
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  updatedAt     DateTime  @updatedAt

  @@index([documentId])
}

// =========================
// GENERATED INVOICE TABLE
// Invoices created by users and paid via Razorpay
// =========================
model GeneratedInvoice {
  id              String   @id @default(uuid())
  userId          Int
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Invoice meta
  invoiceNumber   String
  invoiceDate     String
  placeOfSupply   String
  paymentTerms    String

  // Supplier
  supplierName    String
  supplierGstin   String
  supplierAddress String
  supplierPhone   String

  // Items and taxes stored as JSON
  items           Json
  cgst            Float
  sgst            Float
  igst            Float

  // Totals
  subTotal        Float
  taxTotal        Float
  grandTotal      Float

  // Razorpay payment info
  razorpayOrderId   String   @unique
  razorpayPaymentId String?
  razorpaySignature String?
  paymentStatus     String   @default("pending") // pending | paid

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}